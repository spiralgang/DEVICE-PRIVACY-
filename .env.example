# NVIDIA_API_KEY: Required for NVIDIA AI (integrate.api.nvidia.com) calls.
# Used by the AI FSM privacy/risk analysis (Llama 3.3 70B Instruct).
# Provide it as a Gradle property (-PNVIDIA_API_KEY=...), an environment
# variable, or a line in local.properties so it is baked into BuildConfig.
NVIDIA_API_KEY=MY_NVIDIA_API_KEY

# MISTRAL_API_KEY: Required for Mistral API calls.
# Used by the in-app edge terminal panel.
MISTRAL_API_KEY=MY_MISTRAL_API_KEY
